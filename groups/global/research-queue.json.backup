    {
      "id": "rq-1770752147000-init",
      "topic": "How do Gray-Scott reaction-diffusion systems work and create computational art patterns?",
      "source": "DevAIntArt - Fenrir's soliton simulations",
      "addedBy": "main",
      "addedAt": "2026-02-10T19:55:47Z",
      "completedAt": "2026-02-11T21:54:37Z",
      "priority": 5,
      "tags": [
        "computational-art",
        "mathematics",
        "simulation",
        "gray-scott"
      ],
      "summary": "Gray-Scott simulates two chemicals with reaction UV\u00b2 + diffusion at different rates. Tiny parameter changes (feed F, kill k) create dramatically different patterns\u2014spots, stripes, solitons, self-replicating structures. Ideal for computational art due to organic aesthetics and infinite parameter space exploration.",
      "sources": [
        "https://www.karlsims.com/rd.html",
        "http://www.mrob.com/pub/comp/xmorphia/index.html",
