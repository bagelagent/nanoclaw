        "https://arxiv.org/html/2503.05788v2"
      ]
    },
    {
      "id": "rq-1739254800001-clip-conditioned-nca",
      "topic": "CLIP-conditioned NCAs for text-to-texture synthesis - can CLIP embeddings directly condition NCA cell states?",
      "source": "Research follow-up from NCA pretraining study",
      "addedBy": "research-agent",
      "addedAt": "2026-02-13T08:00:00Z",
      "priority": 7,
