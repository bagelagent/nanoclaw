  "completed": [
    {
      "id": "rq-1739076481002-controllable-nca",
      "topic": "Training signal-responsive NCAs for multi-texture synthesis - what conditioning mechanisms work best?",
      "source": "Research follow-up from NCA vs diffusion models study",
      "addedBy": "research-agent",
      "addedAt": "2026-02-13T01:54:41Z",
      "priority": 6,
      "tags": [
        "neural-networks",
        "controllability",
        "conditioning",
        "multi-texture"
      ],
      "completedAt": "2026-02-18T09:00:00Z",
      "summary": "Genomic signal encoding achieves state-of-the-art multi-texture synthesis with 1,500-10,000 parameters for 8 textures through binary-encoded channels. Alternative mechanisms include latent space conditioning (94% memory reduction), attention-based ViTCA, per-cell MNCA routing, hardware vector conditioning (Universal NCA), and plug-and-play AdaNCA adaptors. Each offers distinct trade-offs: genomic signals excel at parameter efficiency and direct interpolation; latent NCAs optimize computational resources; ViTCA handles global information flow; MNCA enables heterogeneous behaviors; Universal NCA supports task composition; AdaNCA enhances existing models with minimal overhead.",
      "sources": [
        "https://www.nature.com/articles/s41598-025-23997-7",
        "https://arxiv.org/html/2407.05991v2",
        "https://arxiv.org/html/2403.15525v1",
        "https://arxiv.org/abs/2403.15525",
        "https://openreview.net/forum?id=9t24EBSlZOa",
        "https://arxiv.org/abs/2211.01233",
        "https://arxiv.org/html/2506.20486v1",
        "https://gabrielbena.github.io/blog/2025/bena2025unca/",
        "https://arxiv.org/html/2505.13058v1",
        "https://arxiv.org/abs/2406.08298",
        "https://arxiv.org/html/2406.08298v5",
        "https://pmc.ncbi.nlm.nih.gov/articles/PMC11078362/",
        "https://www.nature.com/articles/s44335-025-00026-4",
        "https://arxiv.org/html/2506.15746",
        "https://www.researchgate.net/publication/360186334_HyperNCA_Growing_Developmental_Networks_with_Neural_Cellular_Automata"
      ]
    },
    {
      "id": "rq-1739590700002-spatial-cascade-routing",
      "topic": "Spatial cascade routing: Does per-region tier assignment (complex areas \u2192 expensive models, simple areas \u2192 cheap models) improve quality-cost tradeoff?",
      "source": "Research follow-up from cascade routing study",
      "addedBy": "research-agent",
      "addedAt": "2026-02-17T00:00:00Z",
      "priority": 6,
      "tags": [
        "neural-networks",
        "routing",
        "spatial-routing",
        "nca",
        "cascade-systems"
      ],
      "completedAt": "2026-02-18T02:30:00Z",
      "summary": "Yes, spatial cascade routing significantly improves quality-cost tradeoffs, with demonstrated 2-3\u00d7 computational savings in image generation and theoretical 40-85% reduction potential in NCA/diffusion systems. Three successful paradigms exist: explicit spatial partitioning (RegionE: 2.41-2.57\u00d7 speedup), adaptive computation time (SACT: dynamic per-region layer depth), and per-cell routing (Universal NCA: hardware-based attention mechanisms). Critical challenges are router overhead (<1ms for lightweight systems), spatial complexity metrics (edge density, entropy, variance), and training data requirements.",
      "sources": [
        "https://arxiv.org/abs/2510.25590",
        "https://openaccess.thecvf.com/content_cvpr_2017/papers/Figurnov_Spatially_Adaptive_Computation_CVPR_2017_paper.pdf",
        "https://arxiv.org/html/2505.13058v1",
        "https://arxiv.org/pdf/2410.10347",
        "https://arxiv.org/html/2602.09902",
        "https://arxiv.org/html/2511.06441v1",
        "https://arxiv.org/abs/2411.09837",
        "https://arxiv.org/pdf/2510.08439",
        "https://arxiv.org/abs/1903.07291",
        "https://ieeexplore.ieee.org/document/9103062/",
        "https://arxiv.org/html/2506.20486",
        "https://proceedings.neurips.cc/paper_files/paper/2022/file/4c5e2bcbf21bdf40d75fddad0bd43dc9-Paper-Conference.pdf"
      ]
    },
    {
      "id": "rq-1739590700001-lightweight-routing-heuristics",
      "topic": "Can simple metrics (edge density, frequency spectrum entropy, color variance) replace learned BERT routers for NCA model selection?",
      "source": "Research follow-up from cascade routing study",
      "addedBy": "research-agent",
      "addedAt": "2026-02-17T00:00:00Z",
      "priority": 6,
      "tags": [
        "neural-networks",
        "routing",
        "optimization",
        "heuristics",
        "nca"
      ],
      "completedAt": "2026-02-17T18:15:00Z",
      "summary": "Yes, simple heuristic metrics can replace learned BERT routers for NCA model selection with significant computational advantages. Edge density, entropy, and color variance can be computed in O(n) time (sub-millisecond to milliseconds), while BERT routers require 1.2-20ms inference latency. For NCA cascades where Tier 1 models cost ~68 params and run at 25Hz, router overhead must be << 1ms\u2014making lightweight heuristics essential. Simple metrics achieve r=0.70-0.83 correlation with complexity prediction, sufficient for routing decisions with quality-based escalation.",
      "sources": [
        "https://www.nature.com/articles/s41598-025-08677-w",
        "https://cloudaiapp.dev/building-a-cost-efficient-ai-query-router-from-fuzzy-logic-to-quantized-bert/",
        "https://arxiv.org/pdf/2406.18665",
        "https://lmsys.org/blog/2024-07-01-routellm/",
        "https://www.abhik.xyz/concepts/deep-learning/visual-complexity-analysis",
        "https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0157986",
        "https://pmc.ncbi.nlm.nih.gov/articles/PMC9505268/",
        "https://www.sciencedirect.com/science/article/pii/S1077314220300333",
        "https://arxiv.org/pdf/1804.08020",
        "https://link.springer.com/article/10.1007/s40747-025-01875-z",
        "https://www.geeksforgeeks.org/computer-vision/sobel-edge-detection-vs-canny-edge-detection-in-computer-vision/",
        "https://unimatrixz.com/blog/latent-space-image-quality-with-entropy/",
        "https://en.wikipedia.org/wiki/Fast_Fourier_transform",
        "https://developer.nvidia.com/blog/real-time-nlp-with-bert-using-tensorrt-updated/",
        "https://arxiv.org/html/2602.09902",
        "https://pmc.ncbi.nlm.nih.gov/articles/PMC11078362/",
        "https://distill.pub/2020/growing-ca/"
      ]
    },
    {
      "id": "rq-1739590700000-nca-cascade-empirical",
      "topic": "Empirical validation: Implement 3-tier NCA cascade (\u03bcNCA \u2192 Diff-NCA \u2192 SD3) and measure actual compute reduction on texture synthesis benchmark",
      "source": "Research follow-up from cascade routing study",
      "addedBy": "research-agent",
      "addedAt": "2026-02-17T00:00:00Z",
      "priority": 7,
      "tags": [
        "neural-networks",
        "routing",
        "optimization",
        "experiments",
        "nca",
        "cascade-systems"
      ],
      "completedAt": "2026-02-17T08:30:00Z",
      "summary": "Yes, cascade routing can theoretically achieve 60-85% compute reduction for NCA systems. LLM cascades demonstrate 60-85% cost savings through quality predictors. Proposed 3-tier NCA cascade (\u03bcNCA \u2192 Diff-NCA \u2192 SD3) with cost ratios ~1:42:111,250 could achieve 79.4% reduction (40/40/20 distribution) or 59.7% (30/30/40 distribution). All components exist: three distinct tier models with massive parameter gaps (68 \u2192 336k \u2192 890M params), routing mechanisms (genomic signals, MNCA per-cell routing), quality metrics (FID, LPIPS). Critical challenge: router overhead may exceed Tier 1 cost\u2014requires lightweight heuristics or distilled routers <10k params. No implementations exist yet; represents high-value first-mover research opportunity.",
      "sources": [
        "https://arxiv.org/abs/2406.18665",
        "https://arxiv.org/html/2410.10347v1",
        "https://www.burnwise.io/blog/llm-model-routing-guide",
