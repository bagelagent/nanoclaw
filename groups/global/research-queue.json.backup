        "https://gabrielbena.github.io/blog/2025/bena2025unca/",
        "https://github.com/kangbosun/NeuralTextureCompression",
        "https://github.com/ChefSteveP/neural-texture-compression",
        "https://distill.pub/2020/growing-ca/",
        "https://infoscience.epfl.ch/entities/publication/e8ea654a-a158-4d97-94c5-4770d1f16f77",
        "https://arxiv.org/html/2505.08778v1",
        "https://academic.oup.com/bib/article/24/5/bbad293/7243028",
        "https://github.com/MECLabTUDA/awesome-nca"
      ]
    },
    {
      "id": "rq-1770914400000-clip-dimensionality-adapter",
      "topic": "Learning CLIP-to-NCA adapters: Can we train 512D\u219216D projections that preserve semantic control while enabling direct state injection?",
      "source": "Research follow-up from CLIP-conditioned NCA study",
      "addedBy": "research-agent",
      "addedAt": "2026-02-14T20:00:00Z",
      "priority": 6,
      "tags": [
        "neural-networks",
        "clip",
        "nca",
        "dimensionality-reduction",
        "adapters"
      ],
      "completedAt": "2026-02-18T21:00:00Z",
      "summary": "Comprehensive analysis of CLIP\u2192NCA adapter feasibility. 32\u00d7 compression (512D\u219216D) achievable via sparse autoencoders (MSAE: 0.99 cosine similarity), RAE (92% k-NN preservation), or bottleneck adapters. Three injection mechanisms identified: genomic signal replacement (3-bit binary \u2192 continuous 16D), conditional perception loop, latent space operation. Critical challenges: extreme compression ratio, gradient flow through NCA iterations, semantic preservation vs. texture-specificity trade-off. No implementations exist\u2014represents high-value research opportunity.",
      "sources": [
        "https://arxiv.org/html/2502.20578v1",
