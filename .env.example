ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here
DISCORD_BOT_TOKEN=your-discord-token-here
ASSISTANT_NAME=Bagel

# GitHub Integration
# Generate a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo (full repository access)
GITHUB_TOKEN=
GITHUB_BOT_USERNAME=bagel-bot

# Webhook Configuration
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use this same secret when configuring the webhook in GitHub repo settings
GITHUB_WEBHOOK_SECRET=
WEBHOOK_PORT=3000
